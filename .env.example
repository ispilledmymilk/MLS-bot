# Google OAuth (required for domain-restricted access)
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Use "Desktop app" as application type.
# Add this redirect URI to your OAuth client:
#   http://127.0.0.1:3099/oauth2/callback

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
ALLOWED_DOMAIN=yourcompany.com
